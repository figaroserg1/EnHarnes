{
  "version": 1,
  "description": "When code in a watchPath changes, verify that the listed docs are still accurate.",
  "tiers": ["low", "medium", "high"],
  "watchPaths": ["src/", "scripts/harness/", "policies/"],
  "docsDriftRules": [
    {
      "watch": "src/",
      "docs": [
        "ARCHITECTURE.md",
        "docs/generated/db-schema.md"
      ]
    },
    {
      "watch": "src/Providers/",
      "docs": [
        "ARCHITECTURE.md",
        "docs/design-docs/system-spec.md"
      ]
    },
    {
      "watch": "scripts/harness/",
      "docs": [
        "AGENTS.md",
        "docs/PROJECT_OBSERVABILITY.md"
      ]
    },
    {
      "watch": "scripts/harness/code-quality/",
      "docs": [
        "docs/harness/GOLDEN_PRINCIPLES.md",
        "docs/harness/WORKFLOW_RULES.md"
      ]
    },
    {
      "watch": "policies/",
      "docs": [
        "docs/harness/ENTROPY_PRINCIPLES.md"
      ]
    }
  ]
}
