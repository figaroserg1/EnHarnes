{
  "version": 1,
  "description": "When code in a watchPath changes, verify that the listed docs are still accurate.",
  "tiers": ["low", "medium", "high"],
  "watchPaths": ["src/", ".claude/skills/", "policies/"],
  "docsDriftRules": [
    {
      "watch": "src/",
      "docs": [
        "ARCHITECTURE.md",
        "docs/generated/db-schema.md"
      ]
    },
    {
      "watch": "src/Providers/",
      "docs": [
        "ARCHITECTURE.md",
        "docs/design-docs/system-spec.md"
      ]
    },
    {
      "watch": ".claude/skills/harness.linters/",
      "docs": [
        "AGENTS.md",
        ".claude/skills/harness.core/docs/GOLDEN_PRINCIPLES.md"
      ]
    },
    {
      "watch": ".claude/skills/harness.ci/",
      "docs": [
        "AGENTS.md",
        ".claude/skills/harness.core/docs/WORKFLOW_RULES.md"
      ]
    },
    {
      "watch": "policies/",
      "docs": [
        ".claude/skills/harness.core/docs/ENTROPY_PRINCIPLES.md"
      ]
    }
  ]
}
